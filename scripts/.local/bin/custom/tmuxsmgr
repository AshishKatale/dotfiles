#!/usr/bin/env bash

help=$(cat<<EOF
  -h       --help                show this message
  -j       --info                print tmux session info json for waybar
  ${0##*/} /path/to/dir          create new tmux session at given path
EOF
)

case "$1" in
  "-h"|"--help")
    echo "$help"
    exit 0
  ;;
  "-s"|"--special")
    current_session=$(tmux display-message -p "#S")
    special_attached=$(tmux ls | grep "special_$current_session:" | grep attached | wc -l)
    if [ "${current_session:0:8}" = "special_" ]; then
      tmux detach -s "$current_session"
    elif [ 1 -eq $special_attached ]; then
      tmux detach -s "special_$current_session"
    else
      tmux display-popup -T ' Special ' -E -w '85%' -h '85%' "tmux new-session -A -D -s special_$current_session"
    fi
    exit 0
  ;;
  "-j"|"--info")
    if (tmux ls | grep -q attached) 2> /dev/null; then
      if (tmux ls | grep -qv attached) 2> /dev/null; then
        SSN_COUNT="<span color='#8C8FA1'> <i>+$(tmux ls | grep -v attached | wc -l)</i></span>"
      fi
      SSN_NAME="$(tmux ls | grep attached | cut -d: -f1 | awk 'ORS=", "')"
      TMUX_INFO="${SSN_NAME%", "}${SSN_COUNT}"
      TOOLTIP="$(tmux ls -F '#S' | awk '{printf " %d %s \\n", NR, $0}')"
    elif (tmux ls) &> /dev/null; then
      TMUX_INFO="sessions: $(tmux ls | wc -l)"
      TOOLTIP="$(tmux ls -F '#S' | awk '{printf " %d %s \\n", NR, $0}')"
    fi
    echo '{"text":"'$TMUX_INFO'","tooltip":"'${TOOLTIP%\\n}'","class":"tmuxinfo"}'
    exit 0
  ;;
esac

SEPARATOR=' '
tmux_pgrep="$(pgrep tmux)"
if [ -n "$tmux_pgrep" ] && [ -n "$(tmux ls | wc -l)" ]; then
  existing_sessions=$(
    tmux ls -F '#S #{pane_start_path}'
    echo "$SEPARATOR"
  )
fi

if [ -n "$1" ] && [ -d "$1" ]; then
  selected_dirpath=$(realpath "$1")
elif command -v fd &> /dev/null; then
  projects=$(
    [ -n "$existing_sessions" ] && echo "$existing_sessions"                            # contains fields - session name, session's cwd
    echo $HOME/dotfiles $HOME/dotfiles                                                  # duplicate dir names for 2 required fields
    fd --type=directory --min-depth=1 --max-depth=2 . $HOME/workspace --exec echo {} {} # ^?
  )
else
  projects=$(
    [ -n "$existing_sessions" ] && echo "$existing_sessions"                 # contains fields - session name, session's cwd
    echo $HOME/dotfiles $HOME/dotfiles                                       # duplicate dir names for 2 required fields
    find $HOME/workspace -mindepth 1 -maxdepth 2 -type d -exec echo {} {} \; # ^?
  )
fi

if [ -n "$projects" ]; then
  selected_dirpath=$(echo "$projects" | fzf \
    --bind 'ctrl-x:execute-silent(tmux kill-session -t {1})+abort' \
    --tmux='center,50%,40%' --border-label ' TMUX Session Manager ' --scheme='path' \
    --delimiter=' ' --with-nth=1 --accept-nth=2 # display 1st field - session name, return 2nd field - dir path on selection
  )
fi

if [ -z "$selected_dirpath" ] || [ "$selected_dirpath" = "$SEPARATOR" ]; then
  exit 0
fi

selected_dirname=$(basename "$selected_dirpath" | tr . _)
selected_parent_dirname="$(basename $(dirname "$selected_dirpath") | tr . _)"
session_name="$selected_parent_dirname/$selected_dirname"

if [ -z "$TMUX" ] && [ -z "$tmux_pgrep" ]; then
  tmux new-session -s "$session_name" -c "$selected_dirpath"
  exit 0
fi

if ! tmux has-session -t "$session_name" 2> /dev/null; then
  tmux new-session -ds "$session_name" -c "$selected_dirpath"
fi

if [ -n "$TMUX" ]; then
  tmux switch-client -t "$session_name"
else
  tmux attach-session -t "$session_name"
fi

